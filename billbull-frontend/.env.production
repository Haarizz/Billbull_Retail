# Production (VPS): nginx reverse-proxies both frontend and backend through the same domain.
# Leave empty so the code falls back to window.location.origin at runtime.
VITE_API_BASE_URL=

# Phase 3 cutover flag for POS <-> Back Office PrintTemplate unification.
# When true, POS resolves real branch-scoped PrintTemplate rows (category
# "POS Invoice"/"POS Credit Note") instead of buildPosA4Template's fabricated
# in-memory template. Local/dev-only for now — do not set in .env.production.
VITE_USE_NEW_POS_PRINT_TEMPLATE=true
